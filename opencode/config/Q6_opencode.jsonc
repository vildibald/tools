{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server",
      "options": {
        "baseURL": "http://9800x3d-96-5080-3x5070ti:8080/v1"
      },
      "models": {
        "Qwen3.6-27B": {
          "name": "Qwen3.6 27B",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "Gemma-4-31B": {
          "name": "Gemma 4 31B",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "mcp": {
    "gitlab": {
      "type": "remote",
      "url": "https://gitlab.devops.telekom.de/api/v4/mcp"
    }
  },
  "agent": {
    "explore": {
      "mode": "subagent",
      "model": "llama.cpp/Gemma-4-31B",
      "description": "Explore the local repository only: find files, search symbols and keywords, inspect code paths, and answer codebase questions without external research or edits.",
      "prompt": "Explore only. Inspect the local repository with read-only tools. Use grep/glob/list/read and safe shell search commands to find relevant files, symbols, call paths, and implementation details. Return concise findings with concrete file references. Do not modify files. Do not use web search or external documentation; delegate broader dependency/API research to the research subagent.",
      "permission": {
        "edit": "deny",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "read": "allow",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "tree": "allow",
          "tree *": "allow",
          "find *": "allow",
          "fd *": "allow",
          "rg": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git branch*": "allow",
          "git rev-parse*": "allow",
          "git grep*": "allow",
          "git ls-files*": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny"
      }
    },
    "research": {
      "mode": "subagent",
      "model": "llama.cpp/Qwen3.6-27B",
      "description": "Research the repository, dependencies, APIs, and implementation context before planning or building.",
      "prompt": "Research only. Inspect relevant files, docs, history, and external references when useful. Return concise findings, constraints, risks, and concrete file references. Do not modify files.",
      "permission": {
        "edit": "deny",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "read": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "llama.cpp/Qwen3.6-27B",
      "description": "Plan changes using research findings before implementation.",
      "prompt": "Plan first. For non-trivial work, delegate repository/context discovery to the research subagent, then produce a concrete implementation plan. Do not edit product code while planning."
    },
    "build": {
      "mode": "primary",
      "model": "llama.cpp/Qwen3.6-27B",
      "description": "Implement planned changes and verify them.",
      "prompt": "Build from the agreed plan. Make focused edits, run relevant checks, and delegate final code review to the review subagent before reporting completion."
    },
    "review": {
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "description": "Review completed changes for bugs, regressions, security issues, and missing tests.",
      "prompt": "Review only. Inspect diffs and relevant surrounding code. Prioritize concrete defects, regressions, security issues, and missing tests. Do not modify files.",
      "permission": {
        "edit": "deny",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "read": "allow",
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "rg *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny"
      }
    }
  },
  "default_agent": "plan",
  "lsp": true
}
