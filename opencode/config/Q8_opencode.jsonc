{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "ls": "allow",
      "ls *": "allow",
      "git": "allow",
      "git *": "allow",
      "read *": "allow",
      "grep *": "allow",
      "rg *": "allow"
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server",
      "options": {
        "baseURL": "http://9800x3d-96-5080-3x5070ti:8080/v1"
      },
      "models": {
        "Qwen3.6-27B": {
          "name": "Qwen3.6 27B",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "Gemma-4-31B": {
          "name": "Gemma 4 31B",
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "mcp": {
    "gitlab": {
      "type": "remote",
      "url": "https://gitlab.devops.telekom.de/api/v4/mcp"
    }
  },
  "lsp": true
}
